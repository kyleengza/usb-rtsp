#!/usr/bin/env python3
"""Render mediamtx.yml from cameras.yml + profiles.yml.

Inputs:
  --cameras    path to cameras.yml      (default: ~/.config/usb-rtsp/cameras.yml)
  --profiles   path to profiles.yml     (default: <repo>/etc/profiles.yml)
  --out        path to mediamtx.yml     (default: ~/.config/usb-rtsp/mediamtx.yml)

ffmpeg pipeline per camera (MJPG passthrough = -c copy = ~0% CPU):
  ffmpeg -f v4l2 -input_format MJPG -video_size WxH -framerate F
         -i /dev/v4l/by-id/...-video-index0
         -c copy -f rtsp -rtsp_transport <transport>
         rtsp://127.0.0.1:$RTSP_PORT/$MTX_PATH

For YUYV we need to encode (uncompressed YUYV over RTP isn't supported by mediamtx
publishers in any useful way), so we transcode to MJPEG via ffmpeg's mjpeg encoder.
H264-encode profile uses libx264 ultrafast (CPU-only on Pi 5 — no HW encoder).
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

import yaml

REPO_ROOT = Path(__file__).resolve().parent.parent
DEFAULT_CONFIG_DIR = Path(os.environ.get("USB_RTSP_CONFIG_DIR", Path.home() / ".config" / "usb-rtsp"))

# v4l2 FOURCC → ffmpeg `-input_format` string. ffmpeg's v4l2 demuxer doesn't accept
# the raw FOURCC; it wants its own codec/pixfmt names. (E.g. MJPG → "mjpeg", not "mjpg".)
V4L2_TO_FFMPEG_INPUT_FORMAT = {
    "MJPG": "mjpeg",
    "YUYV": "yuyv422",
    "UYVY": "uyvy422",
    "H264": "h264",
    "HEVC": "hevc",
    "NV12": "nv12",
    "YV12": "yuv420p",
    "RGB3": "rgb24",
    "BGR3": "bgr24",
}


def ffmpeg_input_format(fourcc: str) -> str:
    return V4L2_TO_FFMPEG_INPUT_FORMAT.get(fourcc.upper(), fourcc.lower())


def h264_bitrate(width: int, height: int) -> str:
    """Sensible bitrate target for libx264 ultrafast given a resolution.

    Tuned for WiFi-tethered phone clients — 'ultrafast' produces less
    efficient bitstreams than 'medium', so we leave headroom. Bump these
    up if you only consume from wired desktop clients.
    """
    pixels = width * height
    if pixels >= 1920 * 1080: return "2500k"
    if pixels >= 1280 * 720:  return "1500k"
    if pixels >= 640 * 480:   return "800k"
    return "500k"


def ffmpeg_cmd(cam: dict, profile: dict) -> str:
    """Build the ffmpeg command for a camera's runOnInit.

    `format` is the v4l2 *input* format (what the camera produces).
    `encode` is the *output* codec we ship to mediamtx over RTSP:

      - "h264"   — libx264 ultrafast (universal compat; default for MJPG/YUYV)
      - "mjpeg"  — RFC 2435 RTP/JPEG (lighter CPU but fragile across phones,
                   esp. with cheap UVC cams that emit nonstandard JPEG)
      - "copy"   — passthrough (only valid when input format is already a
                   codec the RTSP server accepts: native H264 cams mostly)

    H.264 is the default because MJPEG-over-RTSP (RFC 2435) can't express
    the JPEG quirks most cheap webcams produce — mediamtx drops fragments
    and mobile players (VLC Android) glitch / disconnect. libx264 ultrafast
    at 1080p30 stays under one Cortex-A76 core on a Pi 5.
    """
    by_id_path = f"/dev/v4l/by-id/{cam['by_id']}"
    fmt = cam["format"]
    w, h, fps = cam["width"], cam["height"], cam["fps"]
    transport = profile["transport"]
    encode = cam.get("encode") or default_encode(fmt)

    common_in = (
        f"-hide_banner -loglevel warning "
        f"-f v4l2 -input_format {ffmpeg_input_format(fmt)} "
        f"-video_size {w}x{h} -framerate {fps} "
        f"-i {by_id_path}"
    )
    common_out = (
        f"-f rtsp -rtsp_transport {transport} "
        f"rtsp://127.0.0.1:$RTSP_PORT/$MTX_PATH"
    )

    if encode == "copy":
        codec = "-c copy"
    elif encode == "mjpeg":
        codec = "-c:v mjpeg -q:v 3 -huffman default"
    elif encode == "h264":
        bitrate = h264_bitrate(w, h)
        # -profile baseline + -vf format=yuv420p forces TV-range yuv420p in the
        # SPS (ffmpeg/libx264 will otherwise tag MJPEG-derived input as
        # yuvj420p / full-range, which VLC and many phone H.264 decoders
        # silently reject — the RTSP session opens but no video renders).
        # -an ensures the SDP advertises no audio track (some players choke
        # on streams that promise audio but never send any).
        codec = (
            f"-an "
            f"-vf format=yuv420p,scale=in_range=full:out_range=tv "
            f"-c:v libx264 -preset ultrafast -tune zerolatency "
            f"-profile:v baseline -level 3.1 "
            f"-pix_fmt yuv420p -color_range tv "
            f"-b:v {bitrate} -maxrate {bitrate} -bufsize {bitrate} "
            f"-g {fps * 2} -keyint_min {fps} -bf 0"
        )
    else:
        codec = "-c copy"

    return f"ffmpeg {common_in} {codec} {common_out}"


def default_encode(fmt: str) -> str:
    """Pick a sensible output encode for a given v4l2 input format."""
    if fmt == "H264":
        return "copy"
    return "h264"


def build_config(cameras_doc: dict, profiles_doc: dict) -> dict:
    """Build the mediamtx config dict."""
    cams = cameras_doc.get("cameras", [])
    # union of all per-cam profile knobs → top-level mediamtx settings
    # (mediamtx has these globally; we pick the most generous of the active profiles)
    profile_names = {c.get("profile", "balanced") for c in cams} or {"balanced"}
    active = [profiles_doc[n] for n in profile_names if n in profiles_doc] or [profiles_doc["balanced"]]
    read_buf = max(p["read_buffer_count"] for p in active)
    write_q = max(p["write_queue_size"] for p in active)

    paths = {}
    for cam in cams:
        prof_name = cam.get("profile", "balanced")
        profile = profiles_doc.get(prof_name, profiles_doc["balanced"])
        paths[cam["name"]] = {
            "source": "publisher",
            "runOnInit": ffmpeg_cmd(cam, profile),
            "runOnInitRestart": True,
        }

    return {
        # global
        "logLevel": "info",
        "logDestinations": ["stdout"],
        "readTimeout": "10s",
        "writeTimeout": "10s",
        "readBufferCount": read_buf,
        "writeQueueSize": write_q,
        "udpMaxPayloadSize": 1472,
        # control api (loopback only — admin panel talks to this)
        "api": True,
        "apiAddress": "127.0.0.1:9997",
        # rtsp server — both TCP and UDP allowed. VLC desktop has a buggy
        # retry path when a TCP-only server returns 461 to its first UDP
        # SETUP (sends SETUP without DESCRIBE → mediamtx logs "invalid URL
        # ((null))" → VLC gives up). With UDP enabled, VLC negotiates UDP
        # cleanly on a fresh DESCRIBE → SETUP → PLAY. Most Android RTSP
        # players default to TCP. The phone-on-WiFi-on-VLC-Android case
        # (where UDP packet loss kills the session) is the one combination
        # the user has to fix client-side: force RTSP-TCP in app settings.
        "rtsp": True,
        "rtspAddress": ":8554",
        "rtspTransports": ["tcp", "udp"],
        # disable other protocols (we're RTSP-only by plan; flip these later if needed)
        "rtmp": False,
        "hls": False,
        "webrtc": False,
        "srt": False,
        # paths
        "paths": paths,
    }


def seed_cameras_from_detect(detect_path: Path | None = None) -> dict:
    """Generate a cameras.yml dict by running usb-rtsp-detect and picking defaults."""
    detect_bin = detect_path or (REPO_ROOT / "bin" / "usb-rtsp-detect")
    out = subprocess.run([str(detect_bin)], capture_output=True, text=True, check=True).stdout
    detected = json.loads(out)
    cams = []
    for i, c in enumerate(detected.get("cameras", [])):
        d = c.get("default")
        if not d:
            continue
        cams.append({
            "name": f"cam{i}",
            "by_id": c["by_id"],
            "format": d["format"],
            "width": d["width"],
            "height": d["height"],
            "fps": d["fps"],
            "encode": default_encode(d["format"]),
            "profile": "balanced",
        })
    return {"cameras": cams}


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--cameras", default=str(DEFAULT_CONFIG_DIR / "cameras.yml"))
    p.add_argument("--profiles", default=str(REPO_ROOT / "etc" / "profiles.yml"))
    p.add_argument("--out", default=str(DEFAULT_CONFIG_DIR / "mediamtx.yml"))
    p.add_argument(
        "--seed-if-missing",
        action="store_true",
        help="if --cameras file doesn't exist, auto-detect cameras and write it first",
    )
    p.add_argument(
        "--print",
        action="store_true",
        help="print rendered config to stdout instead of writing --out",
    )
    args = p.parse_args()

    cameras_path = Path(args.cameras)
    profiles_path = Path(args.profiles)
    out_path = Path(args.out)

    if not cameras_path.exists():
        if args.seed_if_missing:
            cameras_path.parent.mkdir(parents=True, exist_ok=True)
            seeded = seed_cameras_from_detect()
            cameras_path.write_text(yaml.safe_dump(seeded, sort_keys=False))
            print(f"seeded {cameras_path} from auto-detect ({len(seeded['cameras'])} cam(s))", file=sys.stderr)
        else:
            print(f"error: {cameras_path} not found (use --seed-if-missing to auto-detect)", file=sys.stderr)
            return 1

    cameras_doc = yaml.safe_load(cameras_path.read_text()) or {}
    profiles_doc = yaml.safe_load(profiles_path.read_text()) or {}
    config = build_config(cameras_doc, profiles_doc)
    rendered = yaml.safe_dump(config, sort_keys=False, default_flow_style=False)

    if args.print:
        print(rendered, end="")
    else:
        out_path.parent.mkdir(parents=True, exist_ok=True)
        out_path.write_text(rendered)
        print(f"wrote {out_path}", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
