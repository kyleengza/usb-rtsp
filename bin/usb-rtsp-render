#!/usr/bin/env python3
"""Render mediamtx.yml from cameras.yml + profiles.yml.

Inputs:
  --cameras    path to cameras.yml      (default: ~/.config/usb-rtsp/cameras.yml)
  --profiles   path to profiles.yml     (default: <repo>/etc/profiles.yml)
  --out        path to mediamtx.yml     (default: ~/.config/usb-rtsp/mediamtx.yml)

ffmpeg pipeline per camera (MJPG passthrough = -c copy = ~0% CPU):
  ffmpeg -f v4l2 -input_format MJPG -video_size WxH -framerate F
         -i /dev/v4l/by-id/...-video-index0
         -c copy -f rtsp -rtsp_transport <transport>
         rtsp://127.0.0.1:$RTSP_PORT/$MTX_PATH

For YUYV we need to encode (uncompressed YUYV over RTP isn't supported by mediamtx
publishers in any useful way), so we transcode to MJPEG via ffmpeg's mjpeg encoder.
H264-encode profile uses libx264 ultrafast (CPU-only on Pi 5 — no HW encoder).
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

import yaml

REPO_ROOT = Path(__file__).resolve().parent.parent
DEFAULT_CONFIG_DIR = Path(os.environ.get("USB_RTSP_CONFIG_DIR", Path.home() / ".config" / "usb-rtsp"))


def _load_auth() -> dict:
    """Read auth.yml + the secret stream password (if streams auth is on).

    Returns {"streams_user": str|None, "streams_pass": str|None}.
    """
    auth_yml = DEFAULT_CONFIG_DIR / "auth.yml"
    pass_file = DEFAULT_CONFIG_DIR / ".stream-pass"
    out = {"streams_user": None, "streams_pass": None}
    if not auth_yml.exists():
        return out
    try:
        cfg = yaml.safe_load(auth_yml.read_text()) or {}
    except (OSError, yaml.YAMLError):
        return out
    if not (cfg.get("streams") or {}).get("enabled"):
        return out
    user = (cfg["streams"].get("user") or "stream").strip()
    if not pass_file.exists():
        return out
    try:
        pw = pass_file.read_text().strip()
    except OSError:
        return out
    if not pw:
        return out
    out["streams_user"] = user
    out["streams_pass"] = pw
    return out

# v4l2 FOURCC → ffmpeg `-input_format` string. ffmpeg's v4l2 demuxer doesn't accept
# the raw FOURCC; it wants its own codec/pixfmt names. (E.g. MJPG → "mjpeg", not "mjpg".)
V4L2_TO_FFMPEG_INPUT_FORMAT = {
    "MJPG": "mjpeg",
    "YUYV": "yuyv422",
    "UYVY": "uyvy422",
    "H264": "h264",
    "HEVC": "hevc",
    "NV12": "nv12",
    "YV12": "yuv420p",
    "RGB3": "rgb24",
    "BGR3": "bgr24",
}


def ffmpeg_input_format(fourcc: str) -> str:
    return V4L2_TO_FFMPEG_INPUT_FORMAT.get(fourcc.upper(), fourcc.lower())


def h264_bitrate_kbps(width: int, height: int, factor: float = 1.0) -> int:
    """Baseline kbps target for libx264 ultrafast at a given resolution,
    scaled by a quality preset's `bitrate_factor`. Tuned to leave headroom
    for WiFi-tethered phones with the 'ultrafast' preset's looser bitstream.
    """
    pixels = width * height
    if pixels >= 1920 * 1080: base = 2500
    elif pixels >= 1280 * 720: base = 1500
    elif pixels >= 640 * 480:  base = 800
    else:                      base = 500
    return max(100, int(round(base * float(factor))))


# ----------------------------------------------------------------------
# allowlists for the per-cam advanced overrides (kept here so render and
# admin/app.py can both import and stay in sync if we ever refactor).
# ----------------------------------------------------------------------
ALLOWED_X264_PRESETS = ("ultrafast", "superfast", "veryfast", "faster", "fast")
ALLOWED_BFRAMES = (0, 1, 2, 3)


def load_quality_presets(path: Path) -> dict:
    return yaml.safe_load(path.read_text()) or {}


def ffmpeg_cmd(cam: dict, profile: dict, qpresets: dict | None = None) -> str:
    """Build the ffmpeg command for a camera's runOnInit.

    `format` is the v4l2 *input* format (what the camera produces).
    `encode` is the *output* codec we ship to mediamtx over RTSP:

      - "h264"   — libx264 ultrafast (universal compat; default for MJPG/YUYV)
      - "mjpeg"  — RFC 2435 RTP/JPEG (lighter CPU but fragile across phones,
                   esp. with cheap UVC cams that emit nonstandard JPEG)
      - "copy"   — passthrough (only valid when input format is already a
                   codec the RTSP server accepts: native H264 cams mostly)

    H.264 is the default because MJPEG-over-RTSP (RFC 2435) can't express
    the JPEG quirks most cheap webcams produce — mediamtx drops fragments
    and mobile players (VLC Android) glitch / disconnect. libx264 ultrafast
    at 1080p30 stays under one Cortex-A76 core on a Pi 5.
    """
    by_id_path = f"/dev/v4l/by-id/{cam['by_id']}"
    fmt = cam["format"]
    w, h, fps = cam["width"], cam["height"], cam["fps"]
    transport = profile["transport"]
    encode = cam.get("encode") or default_encode(fmt)

    # Resolve compression knobs: per-cam override > quality preset > hard fallback.
    qpresets = qpresets or {}
    qprof = qpresets.get(cam.get("quality") or "medium", qpresets.get("medium", {}))
    x264_preset = cam.get("x264_preset") or qprof.get("preset", "ultrafast")
    bitrate_k = cam.get("bitrate_kbps") or h264_bitrate_kbps(w, h, qprof.get("bitrate_factor", 1.0))
    gop_seconds = cam.get("gop_seconds") or qprof.get("gop_seconds", 2)
    bframes = cam.get("bframes") if cam.get("bframes") is not None else qprof.get("bframes", 0)
    mjpeg_qv = cam.get("mjpeg_qv") or qprof.get("mjpeg_qv", 3)

    common_in = (
        f"-hide_banner -loglevel warning "
        f"-f v4l2 -input_format {ffmpeg_input_format(fmt)} "
        f"-video_size {w}x{h} -framerate {fps} "
        f"-i {by_id_path}"
    )
    # publisher writes via loopback; mediamtx authInternalUsers grants the
    # 127.0.0.1/32 source publish access without requiring credentials, so
    # we don't have to embed a password in the runOnInit string.
    common_out = (
        f"-f rtsp -rtsp_transport {transport} "
        f"rtsp://127.0.0.1:$RTSP_PORT/$MTX_PATH"
    )

    if encode == "copy":
        codec = "-c copy"
    elif encode == "mjpeg":
        codec = f"-c:v mjpeg -q:v {int(mjpeg_qv)} -huffman default"
    elif encode == "h264":
        # B-frames are only valid in profile=main or higher. Auto-promote.
        h264_profile = "main" if int(bframes) > 0 else "baseline"
        gop_frames = max(1, int(gop_seconds) * fps)
        # -vf format=yuv420p + -color_range tv forces TV-range yuv420p in the
        # SPS (ffmpeg would otherwise tag MJPEG-derived input as yuvj420p /
        # full-range, which VLC and many phone H.264 decoders silently
        # reject). -an = no audio track in the SDP.
        codec = (
            f"-an "
            f"-vf format=yuv420p,scale=in_range=full:out_range=tv "
            f"-c:v libx264 -preset {x264_preset} -tune zerolatency "
            f"-profile:v {h264_profile} -level 3.1 "
            f"-pix_fmt yuv420p -color_range tv "
            f"-b:v {bitrate_k}k -maxrate {bitrate_k}k -bufsize {bitrate_k}k "
            f"-g {gop_frames} -keyint_min {fps} -bf {int(bframes)}"
        )
    else:
        codec = "-c copy"

    return f"ffmpeg {common_in} {codec} {common_out}"


def default_encode(fmt: str) -> str:
    """Pick a sensible output encode for a given v4l2 input format."""
    if fmt == "H264":
        return "copy"
    return "h264"


def build_config(cameras_doc: dict, profiles_doc: dict, qpresets_doc: dict | None = None) -> dict:
    """Build the mediamtx config dict."""
    cams = cameras_doc.get("cameras", [])
    qpresets_doc = qpresets_doc or {}
    # union of all per-cam profile knobs → top-level mediamtx settings
    # (mediamtx has these globally; we pick the most generous of the active profiles)
    profile_names = {c.get("profile", "balanced") for c in cams} or {"balanced"}
    active = [profiles_doc[n] for n in profile_names if n in profiles_doc] or [profiles_doc["balanced"]]
    read_buf = max(p["read_buffer_count"] for p in active)
    write_q = max(p["write_queue_size"] for p in active)

    paths = {}
    for cam in cams:
        prof_name = cam.get("profile", "balanced")
        profile = profiles_doc.get(prof_name, profiles_doc["balanced"])
        paths[cam["name"]] = {
            "source": "publisher",
            "runOnInit": ffmpeg_cmd(cam, profile, qpresets_doc),
            "runOnInitRestart": True,
        }

    # auth — authInternalUsers if enabled, else any/any (open).
    auth = _load_auth()
    if auth.get("streams_user") and auth.get("streams_pass"):
        auth_block = {
            "authMethod": "internal",
            "authInternalUsers": [
                # the loopback publisher (our runOnInit ffmpeg) gets
                # unrestricted access from 127.0.0.1 with no creds
                {
                    "user": "any",
                    "pass": "",
                    "ips": ["127.0.0.1/32", "::1/128"],
                    "permissions": [
                        {"action": "publish"},
                        {"action": "read"},
                        {"action": "playback"},
                        {"action": "api"},
                        {"action": "metrics"},
                        {"action": "pprof"},
                    ],
                },
                # external readers must present these creds (HTTP basic for
                # HLS/WebRTC, RTSP url-embedded for rtsp://user:pass@host/cam)
                {
                    "user": auth["streams_user"],
                    "pass": auth["streams_pass"],
                    "ips": [],
                    "permissions": [
                        {"action": "read"},
                        {"action": "playback"},
                    ],
                },
            ],
        }
    else:
        auth_block = {"authMethod": "internal"}

    return {
        # global
        "logLevel": "info",
        "logDestinations": ["stdout"],
        "readTimeout": "10s",
        "writeTimeout": "10s",
        "readBufferCount": read_buf,
        "writeQueueSize": write_q,
        "udpMaxPayloadSize": 1472,
        **auth_block,
        # control api (loopback only — admin panel talks to this)
        "api": True,
        "apiAddress": "127.0.0.1:9997",
        # rtsp server — both TCP and UDP allowed. (VLC's RTSP client has
        # ongoing compat issues with gortsplib's strict per-track-URL SETUP
        # requirement; ffplay/mpv-direct/most Android apps work fine. For
        # VLC + browser playback, HLS and WebRTC below are the universal
        # fallbacks — same H.264 stream, no re-encode.)
        "rtsp": True,
        "rtspAddress": ":8554",
        "rtspTransports": ["tcp", "udp"],
        # HLS — http://<host>:8888/<path>/index.m3u8 — universal player
        # compat via mpegts variant (.ts segments). LL-HLS / fMP4 (the
        # `lowLatency` variant) trips VLC older than 3.0.18 with a
        # confusing "Codec not supported" error even though the H.264
        # bytes are fine — switch to mpegts for the broadest reach.
        # Latency ≈ 5 s with 1 s segments × 5 in-window.
        "hls": True,
        "hlsAddress": ":8888",
        "hlsAlwaysRemux": False,
        "hlsVariant": "mpegts",
        "hlsSegmentCount": 5,
        "hlsSegmentDuration": "1s",
        "hlsAllowOrigin": "*",
        # WebRTC — http://<host>:8889/<path> — sub-second latency, browser
        # native (Chrome/Safari/Firefox), no app needed. mediamtx handles ICE.
        "webrtc": True,
        "webrtcAddress": ":8889",
        "webrtcAllowOrigin": "*",
        "webrtcLocalUDPAddress": ":8189",
        # rest disabled
        "rtmp": False,
        "srt": False,
        # paths
        "paths": paths,
    }


def seed_cameras_from_detect(detect_path: Path | None = None) -> dict:
    """Generate a cameras.yml dict by running usb-rtsp-detect and picking defaults."""
    detect_bin = detect_path or (REPO_ROOT / "bin" / "usb-rtsp-detect")
    out = subprocess.run([str(detect_bin)], capture_output=True, text=True, check=True).stdout
    detected = json.loads(out)
    cams = []
    for i, c in enumerate(detected.get("cameras", [])):
        d = c.get("default")
        if not d:
            continue
        cams.append({
            "name": f"cam{i}",
            "by_id": c["by_id"],
            "format": d["format"],
            "width": d["width"],
            "height": d["height"],
            "fps": d["fps"],
            "encode": default_encode(d["format"]),
            "profile": "balanced",
        })
    return {"cameras": cams}


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--cameras", default=str(DEFAULT_CONFIG_DIR / "cameras.yml"))
    p.add_argument("--profiles", default=str(REPO_ROOT / "etc" / "profiles.yml"))
    p.add_argument("--quality-presets", default=str(REPO_ROOT / "etc" / "quality-presets.yml"))
    p.add_argument("--out", default=str(DEFAULT_CONFIG_DIR / "mediamtx.yml"))
    p.add_argument(
        "--seed-if-missing",
        action="store_true",
        help="if --cameras file doesn't exist, auto-detect cameras and write it first",
    )
    p.add_argument(
        "--print",
        action="store_true",
        help="print rendered config to stdout instead of writing --out",
    )
    args = p.parse_args()

    cameras_path = Path(args.cameras)
    profiles_path = Path(args.profiles)
    out_path = Path(args.out)

    if not cameras_path.exists():
        if args.seed_if_missing:
            cameras_path.parent.mkdir(parents=True, exist_ok=True)
            seeded = seed_cameras_from_detect()
            cameras_path.write_text(yaml.safe_dump(seeded, sort_keys=False))
            print(f"seeded {cameras_path} from auto-detect ({len(seeded['cameras'])} cam(s))", file=sys.stderr)
        else:
            print(f"error: {cameras_path} not found (use --seed-if-missing to auto-detect)", file=sys.stderr)
            return 1

    cameras_doc = yaml.safe_load(cameras_path.read_text()) or {}
    profiles_doc = yaml.safe_load(profiles_path.read_text()) or {}
    qpresets_path = Path(args.quality_presets)
    qpresets_doc = load_quality_presets(qpresets_path) if qpresets_path.exists() else {}
    config = build_config(cameras_doc, profiles_doc, qpresets_doc)
    rendered = yaml.safe_dump(config, sort_keys=False, default_flow_style=False)

    if args.print:
        print(rendered, end="")
    else:
        out_path.parent.mkdir(parents=True, exist_ok=True)
        out_path.write_text(rendered)
        print(f"wrote {out_path}", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
