#!/usr/bin/env python3
"""Enumerate USB video-capture cameras and emit JSON of their v4l2 capabilities.

Output schema:
  {
    "cameras": [
      {
        "by_id": "usb-VENDOR_PRODUCT_SERIAL-video-index0",
        "device": "/dev/v4l/by-id/<by_id>",
        "card": "Human-readable card name",
        "formats": [
          {"format": "MJPG", "sizes": [{"width": 1920, "height": 1080, "fps": [30]}]},
          {"format": "YUYV", "sizes": [...]}
        ],
        "default": {"format": "MJPG", "width": 1920, "height": 1080, "fps": 30}
      }
    ]
  }
"""
from __future__ import annotations

import json
import re
import subprocess
import sys
from pathlib import Path

BY_ID_DIR = Path("/dev/v4l/by-id")
FMT_RE = re.compile(r"^\s*\[\d+\]:\s*'([^']+)'")
SIZE_RE = re.compile(r"^\s*Size:\s*Discrete\s+(\d+)x(\d+)")
INTERVAL_RE = re.compile(r"\(([\d.]+)\s*fps\)")


def run(cmd: list[str]) -> str:
    return subprocess.run(cmd, capture_output=True, text=True, check=False).stdout


def parse_formats(dev: str) -> list[dict]:
    """Parse `v4l2-ctl --list-formats-ext` into structured records."""
    out = run(["v4l2-ctl", "--device", dev, "--list-formats-ext"])
    formats: list[dict] = []
    cur_fmt: dict | None = None
    cur_size: dict | None = None
    for line in out.splitlines():
        m = FMT_RE.match(line)
        if m:
            cur_fmt = {"format": m.group(1), "sizes": []}
            formats.append(cur_fmt)
            cur_size = None
            continue
        m = SIZE_RE.match(line)
        if m and cur_fmt is not None:
            cur_size = {
                "width": int(m.group(1)),
                "height": int(m.group(2)),
                "fps": [],
            }
            cur_fmt["sizes"].append(cur_size)
            continue
        if "Interval:" in line and cur_size is not None:
            for m in INTERVAL_RE.finditer(line):
                fps = round(float(m.group(1)))
                if fps not in cur_size["fps"]:
                    cur_size["fps"].append(fps)
    # drop sizes with no fps records (defensive); dedupe sizes
    # (some UVC cams advertise the same WxH twice)
    for f in formats:
        seen: dict[tuple[int, int], dict] = {}
        for s in f["sizes"]:
            if not s["fps"]:
                continue
            key = (s["width"], s["height"])
            if key in seen:
                for fps in s["fps"]:
                    if fps not in seen[key]["fps"]:
                        seen[key]["fps"].append(fps)
            else:
                seen[key] = s
        f["sizes"] = sorted(
            seen.values(),
            key=lambda s: (s["width"] * s["height"]),
            reverse=True,
        )
    return [f for f in formats if f["sizes"]]


def card_name(dev: str) -> str:
    out = run(["v4l2-ctl", "--device", dev, "--info"])
    for line in out.splitlines():
        if "Card type" in line:
            return line.split(":", 1)[1].strip()
    return "Unknown"


def pick_default(formats: list[dict]) -> dict | None:
    """Prefer MJPG > H264 > YUYV, max resolution at >=30fps if available, else max overall."""
    if not formats:
        return None
    priority = {"MJPG": 0, "H264": 1, "YUYV": 2}
    fmts_sorted = sorted(formats, key=lambda f: priority.get(f["format"], 99))
    for f in fmts_sorted:
        sizes_30 = [s for s in f["sizes"] if any(fps >= 30 for fps in s["fps"])]
        candidates = sizes_30 or f["sizes"]
        best = max(candidates, key=lambda s: s["width"] * s["height"])
        fps = max(fp for fp in best["fps"] if fp >= 30) if sizes_30 else max(best["fps"])
        return {
            "format": f["format"],
            "width": best["width"],
            "height": best["height"],
            "fps": fps,
        }
    return None


def discover() -> list[dict]:
    if not BY_ID_DIR.is_dir():
        return []
    cams: list[dict] = []
    seen_targets: set[str] = set()
    # only the *-video-index0 nodes; index1+ are metadata/duplicates
    for link in sorted(BY_ID_DIR.glob("*-video-index0")):
        target = link.resolve().as_posix()
        if target in seen_targets:
            continue
        seen_targets.add(target)
        formats = parse_formats(str(link))
        if not formats:
            # not a capture device (metadata-only or pi-internal)
            continue
        cams.append({
            "by_id": link.name,
            "device": str(link),
            "card": card_name(str(link)),
            "formats": formats,
            "default": pick_default(formats),
        })
    return cams


def main() -> int:
    print(json.dumps({"cameras": discover()}, indent=2))
    return 0


if __name__ == "__main__":
    sys.exit(main())
